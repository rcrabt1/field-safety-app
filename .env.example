# Copy to .env and fill in your Supabase project credentials.
# Find these in: Supabase Dashboard → Settings → API

# Public URL for your Supabase project
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key (safe to expose in the browser — RLS enforces access)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Vercel deployment ─────────────────────────────────────────────
# Add these same two variables in: Vercel → Project → Settings → Environment Variables
# Vercel will inject them at build time. Never commit your real .env file.
